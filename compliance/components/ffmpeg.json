{
  "schemaVersion": 1,
  "name": "ffmpeg",
  "version": "8.1.2",
  "sourceUrl": "https://ffmpeg.org/releases/ffmpeg-8.1.2.tar.xz",
  "signatureUrl": "https://ffmpeg.org/releases/ffmpeg-8.1.2.tar.xz.asc",
  "sourceSha256": "464beb5e7bf0c311e68b45ae2f04e9cc2af88851abb4082231742a74d97b524c",
  "sourceArchive": "ffmpeg-8.1.2.tar.xz",
  "builtOutputLicenseSpdx": "LGPL-2.1-or-later",
  "linkage": "dynamic",
  "libraries": ["avcodec", "avfilter", "avformat", "avutil", "swresample", "swscale"],
  "buildArguments": [
    "--disable-gpl",
    "--disable-version3",
    "--disable-nonfree",
    "--disable-autodetect",
    "--disable-programs",
    "--disable-doc",
    "--disable-debug",
    "--disable-static",
    "--enable-shared",
    "--disable-network",
    "--disable-x86asm",
    "--disable-everything",
    "--disable-avdevice",
    "--enable-avfilter",
    "--enable-swresample",
    "--enable-swscale",
    "--disable-iconv",
    "--disable-zlib",
    "--disable-bzlib",
    "--disable-lzma",
    "--enable-protocol=file,pipe",
    "--enable-demuxer=aac,ass,avi,concat,data,flac,flv,h264,hevc,hls,image2,matroska,mov,mp3,mpegts,ogg,srt,wav,webvtt",
    "--enable-muxer=mp4",
    "--enable-decoder=aac,ac3,alac,ass,av1,eac3,flac,h264,hevc,movtext,mp3,mpeg2video,mpeg4,opus,pcm_s16le,pcm_s24le,pcm_s32le,ppm,ssa,subrip,theora,vorbis,vp8,vp9,webvtt",
    "--enable-parser=aac,ac3,av1,h264,hevc,mpeg4video,mpegvideo,opus,vorbis,vp8,vp9",
    "--enable-bsf=aac_adtstoasc,extract_extradata,h264_mp4toannexb,h264_metadata,hevc_mp4toannexb,hevc_metadata,null"
  ],
  "platformArguments": {
    "android": [
      "--enable-jni",
      "--enable-mediacodec",
      "--enable-decoder=h264_mediacodec,hevc_mediacodec,vp9_mediacodec,av1_mediacodec",
      "--enable-encoder=h264_mediacodec"
    ],
    "macos": [
      "--enable-libass",
      "--enable-filter=buffer,buffersink,subtitles,scale,format",
      "--enable-videotoolbox",
      "--enable-encoder=h264_videotoolbox"
    ],
    "ios": []
  }
}
