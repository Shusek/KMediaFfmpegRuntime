{
  "schemaVersion": 1,
  "name": "libass",
  "version": "0.17.4",
  "sourceUrl": "https://github.com/libass/libass/releases/download/0.17.4/libass-0.17.4.tar.xz",
  "sourceSha256": "78f1179b838d025e9c26e8fef33f8092f65611444ffa1bfc0cfac6a33511a05a",
  "sourceArchive": "libass-0.17.4.tar.xz",
  "builtOutputLicenseSpdx": "ISC",
  "linkage": "dynamic",
  "libraries": ["ass"],
  "dependencies": ["freetype", "fribidi", "harfbuzz"],
  "buildArguments": [
    "--wrap-mode=nodownload",
    "--libdir=lib",
    "--auto-features=disabled",
    "--buildtype=release",
    "-Ddefault_library=shared",
    "-Db_lto=false",
    "-Dfontconfig=disabled",
    "-Dasm=disabled",
    "-Dlibunibreak=disabled",
    "-Drequire-system-font-provider=false",
    "-Dtest=disabled",
    "-Dcompare=disabled",
    "-Dprofile=disabled",
    "-Dfuzz=disabled",
    "-Dcheckasm=disabled"
  ],
  "platformArguments": {
    "macos": ["-Dcoretext=enabled"],
    "ios": ["-Dcoretext=enabled"],
    "windows": ["-Ddirectwrite=enabled"]
  }
}
