+int ff_mediacodec_sw_buffer_copy_p010(AVCodecContext *avctx,
+                                        MediaCodecDecContext *s,
+                                        uint8_t *data,
+                                        size_t size,
+                                        FFAMediaCodecBufferInfo *info,
+                                        AVFrame *frame)
+{
+    const int source_stride = s->stride * 2;
+    const int source_slice_height = s->slice_height;
+    const size_t required_size = (size_t)source_stride * source_slice_height * 3 / 2;
+    int plane;
+
+    if (info->offset < 0 || (size_t)info->offset > size ||
+        required_size > size - (size_t)info->offset) {
+        av_log(avctx, AV_LOG_ERROR, "MediaCodec P010 output buffer is truncated\n");
+        return AVERROR_INVALIDDATA;
+    }
+
+    for (plane = 0; plane < 2; ++plane) {
+        const int height = plane == 0 ? avctx->height : avctx->height / 2;
+        const int source_plane_offset = plane == 0 ? 0 : source_stride * source_slice_height;
+        const int crop_top = plane == 0 ? s->crop_top : s->crop_top / 2;
+        const uint8_t *source = data + info->offset + source_plane_offset +
+            crop_top * source_stride + s->crop_left * 2;
+        uint8_t *destination = frame->data[plane];
+        const int copy_width = FFMIN(frame->linesize[plane], FFALIGN(avctx->width, 2) * 2);
+        int row;
+
+        for (row = 0; row < height; ++row) {
+            memcpy(destination, source, copy_width);
+            source += source_stride;
+            destination += frame->linesize[plane];
+        }
+    }
+    return 0;
+}
